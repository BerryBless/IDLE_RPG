# docker-compose.yml이 읽는 환경 변수 템플릿입니다.
# 사용법: 이 파일을 같은 디렉토리에 ".env"로 복사한 뒤 값을 실제 비밀키로 교체하세요.
# ".env"는 .gitignore에 등록되어 있어 커밋되지 않습니다.

# AuthServer가 발급하고 GameServer가 검증하는 HMAC-SHA256 토큰 서명 키입니다. 두 서버가 반드시
# 동일한 값을 공유해야 합니다(docker-compose.yml에서 두 서비스 모두에 이 값을 주입).
# 최소 32바이트(문자) 이상의 고엔트로피 값이어야 합니다 — 미달 시 두 서버 모두 기동 즉시
# InvalidOperationException으로 종료됩니다(Release 빌드 fail-fast, GameServer/Main.cs 참고).
# 아래는 32바이트를 넘기기 위한 예시일 뿐입니다 — 실제 배포 전 반드시 무작위 값으로 교체하세요.
IDLERPG_AUTH_HMAC_SECRET=CHANGE_ME_to_a_random_32byte_min_secret_0123456789

# [DoS 하드닝 — 운영 시 반드시 검토] GameServer의 연결·프레임·유휴 방어 3종은 opt-in이라 미설정 시
# 기존 동작(무제한)을 보존합니다. 스트레스 하네스(plan/stress_harness_0721.md)가 실증하듯 미설정 배포는
# slowloris·오버사이즈 헤더 증폭·프레임 플러드·연결 폭주에 노출됩니다. 값은 배포 규모·머신에 따라
# 다르므로(과소 설정은 정상 트래픽 차단) docker-compose.yml gameserver 서비스의 주석 예시를 참고해
# 배포 환경에 맞게 설정하세요. 게임 하트비트 프로토콜 도입 전까지 IDLE_TIMEOUT은 정상 연결 오판 위험이 있어 신중히.
# IDLERPG_GAME_MAX_CONNECTIONS=50000
# IDLERPG_GAME_MAX_FRAMES_PER_SECOND=100
# IDLERPG_GAME_IDLE_TIMEOUT_SECONDS=120
